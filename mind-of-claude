<script>
const streamEl   = document.getElementById('stream');
const emptyEl    = document.getElementById('empty');
const evCountEl  = document.getElementById('ev-count');
const sessCountEl= document.getElementById('sess-count');
const lastKindEl = document.getElementById('last-kind');
const scrollBtn  = document.getElementById('scroll-btn');

let evCount = 0, sessions = new Set(), autoScroll = true;
const filters = new Set(['thinking','tool_use','tool_result','assistant_text','user_text']);

// ── filter buttons ──────────────────────────────────────────────────────────
document.querySelectorAll('[data-filter]').forEach(btn => {
  btn.addEventListener('click', () => {
    const f = btn.dataset.filter;
    if (filters.has(f)) { filters.delete(f); btn.classList.remove('active'); }
    else                 { filters.add(f);    btn.classList.add('active'); }
    document.querySelectorAll('.card').forEach(c => {
      c.classList.toggle('hidden', !filters.has(c.dataset.kind));
    });
  });
});

document.getElementById('clear-btn').addEventListener('click', () => {
  document.querySelectorAll('.card').forEach(c => c.remove());
  evCount = 0; sessions.clear();
  evCountEl.textContent = '0';
  sessCountEl.textContent = '0';
  if (!emptyEl.parentNode) streamEl.prepend(emptyEl);
});

// ── scroll tracking ─────────────────────────────────────────────────────────
function scrollToBottom() {
  streamEl.scrollTo({ top: streamEl.scrollHeight, behavior: 'smooth' });
  autoScroll = true;
  scrollBtn.classList.remove('visible');
}
streamEl.addEventListener('scroll', () => {
  const atBottom = streamEl.scrollHeight - streamEl.scrollTop - streamEl.clientHeight < 120;
  autoScroll = atBottom;
  scrollBtn.classList.toggle('visible', !atBottom);
});
scrollBtn.addEventListener('click', scrollToBottom);

// ── helpers ──────────────────────────────────────────────────────────────────
function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function trunc(s, n) {
  s = String(s);
  if (s.length <= n) return s;
  return s.slice(0, n) + `\n… [${(s.length-n).toLocaleString()} chars omitted]`;
}
function fmtTs(ts) {
  if (!ts) return '';
  try { return new Date(ts).toLocaleTimeString('en-US',{hour12:false}); }
  catch { return ts.slice(11,19)||''; }
}

const ICONS  = { thinking:'🧠', tool_use:'🔧', tool_result:'📤', assistant_text:'💬', user_text:'👤' };
const LABELS = { thinking:'Thinking', tool_use:'Tool Call', tool_result:'Result', assistant_text:'Response', user_text:'User' };

// ── render card ──────────────────────────────────────────────────────────────
function makeCard(ev) {
  const div = document.createElement('div');
  div.className = 'card ' + ev.kind + (ev.error?' error':'') + (ev.new?' is-new':'');
  div.dataset.kind = ev.kind;
  if (!filters.has(ev.kind)) div.classList.add('hidden');

  const icon  = ICONS[ev.kind]  || '·';
  const label = LABELS[ev.kind] || ev.kind;
  const errLabel = ev.error ? ' Error' : '';

  let bodyHtml = '';

  if (ev.kind === 'tool_use') {
    const raw = JSON.stringify(ev.input, null, 2);
    bodyHtml = `<div class="tool-name">${esc(ev.name)}</div>`
             + `<pre class="json card-body">${esc(trunc(raw, 2000))}</pre>`;
  } else {
    const text = trunc(ev.text || '', ev.kind === 'thinking' ? 900 : 600);
    bodyHtml = `<pre class="card-body">${esc(text)}</pre>`;
  }

  div.innerHTML = `
    <div class="card-meta">
      <span class="card-icon">${icon}</span>
      <span class="card-kind">${label}${errLabel}</span>
      <span class="card-session">${esc(ev.project)} · ${esc(ev.session)}</span>
      <span class="card-ts">${fmtTs(ev.ts)}</span>
    </div>
    ${bodyHtml}
  `;

  // clip detection + expand button
  const body = div.querySelector('.card-body');
  if (body) {
    requestAnimationFrame(() => {
      if (body.scrollHeight > body.clientHeight + 10) {
        body.classList.add('clipped');
        const btn = document.createElement('button');
        btn.className = 'expand-btn';
        btn.textContent = '▼ expand';
        btn.addEventListener('click', () => {
          const exp = body.classList.toggle('expanded');
          body.classList.toggle('clipped', !exp);
          btn.textContent = exp ? '▲ collapse' : '▼ expand';
        });
        div.appendChild(btn);
      }
    });
  }

  return div;
}

// ── add event to stream ───────────────────────────────────────────────────────
function addEvent(ev) {
  if (emptyEl.parentNode) emptyEl.remove();

  evCount++;
  sessions.add(ev.session);
  evCountEl.textContent  = evCount.toLocaleString();
  sessCountEl.textContent = sessions.size;
  lastKindEl.textContent = (ICONS[ev.kind]||'') + ' ' + (LABELS[ev.kind]||ev.kind);

  const card = makeCard(ev);
  streamEl.appendChild(card);

  if (autoScroll) {
    card.scrollIntoView({ behavior: ev.new ? 'smooth' : 'instant', block: 'end' });
  }
}

// ── SSE connection ────────────────────────────────────────────────────────────
function connect() {
  const es = new EventSource('/stream');
  es.onmessage = e => {
    try { addEvent(JSON.parse(e.data)); }
    catch(err) { console.error('parse error', err, e.data); }
  };
  es.onerror = () => {
    console.log('SSE error — reconnecting in 2s');
    es.close();
    setTimeout(connect, 2000);
  };
}
connect();
</script>
