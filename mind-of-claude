#!/usr/bin/env python3
"""Inside the Mind of Claude — live JSONL session viewer.

Watches ~/.claude/projects/**/*.jsonl and streams thinking, tool calls,
and tool results to a browser page via Server-Sent Events.

Usage: mind-of-claude [port]   (default port: 7777)
"""

import html as _html
import json
import queue
import socketserver
import sys
import threading
import time
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path
from datetime import datetime, timezone

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 7777
HOST = sys.argv[2] if len(sys.argv) > 2 else "127.0.0.1"
PROJECTS_DIR = Path.home() / ".claude" / "projects"
POLL_INTERVAL = 0.5          # seconds between file scans
MAX_BUFFER = 1000            # events kept in memory for late-joining clients
INITIAL_FILE_AGE_HOURS = 6   # replay files modified within this window

# ── global state ──────────────────────────────────────────────────────────────
_clients: list[queue.Queue] = []
_clients_lock = threading.Lock()
_event_buffer: list[str] = []          # JSON-encoded event strings
_buffer_lock = threading.Lock()
_file_positions: dict[str, int] = {}   # str(path) -> bytes read so far


def broadcast(event: dict) -> None:
    data = json.dumps(event)
    with _buffer_lock:
        _event_buffer.append(data)
        if len(_event_buffer) > MAX_BUFFER:
            _event_buffer.pop(0)
    with _clients_lock:
        for q in _clients:
            try:
                q.put_nowait(data)
            except queue.Full:
                pass


def parse_entry(entry: dict, source_file: Path) -> list[dict]:
    events = []
    entry_type = entry.get("type", "")
    timestamp = entry.get("timestamp", "")
    session_id = source_file.stem[:8]

    # Make project label human-readable
    proj = source_file.parent.name
    for prefix in ("-Users-ryan-devel-", "-Users-ryan-"):
        if proj.startswith(prefix):
            proj = "~/" + proj[len(prefix):].replace("-", "/", 3)
            break
    if proj == "-Users-ryan":
        proj = "~"

    base = {"ts": timestamp, "session": session_id, "project": proj}

    if entry_type == "assistant":
        content = entry.get("message", {}).get("content", [])
        if isinstance(content, list):
            for block in content:
                btype = block.get("type", "")
                if btype == "thinking":
                    events.append({**base, "kind": "thinking",
                                   "text": block.get("thinking", "")})
                elif btype == "tool_use":
                    events.append({**base, "kind": "tool_use",
                                   "name": block.get("name", ""),
                                   "input": block.get("input", {})})
                elif btype == "text":
                    text = block.get("text", "").strip()
                    if text:
                        events.append({**base, "kind": "assistant_text",
                                       "text": text})

    elif entry_type == "user":
        content = entry.get("message", {}).get("content", [])
        if isinstance(content, str):
            if content.strip():
                events.append({**base, "kind": "user_text",
                               "text": content.strip()})
        elif isinstance(content, list):
            for block in content:
                btype = block.get("type", "")
                if btype == "tool_result":
                    rc = block.get("content", "")
                    if isinstance(rc, list):
                        rc = "\n".join(
                            item.get("text", "") for item in rc
                            if item.get("type") == "text"
                        )
                    events.append({**base, "kind": "tool_result",
                                   "error": bool(block.get("is_error")),
                                   "text": str(rc)})
                elif btype == "text":
                    text = block.get("text", "").strip()
                    if text:
                        events.append({**base, "kind": "user_text",
                                       "text": text})

    return events


def watcher() -> None:
    while True:
        try:
            cutoff = time.time() - INITIAL_FILE_AGE_HOURS * 3600
            for fpath in PROJECTS_DIR.rglob("*.jsonl"):
                try:
                    stat = fpath.stat()
                    key = str(fpath)
                    prev = _file_positions.get(key)

                    if prev is None:
                        _file_positions[key] = stat.st_size
                        if stat.st_mtime >= cutoff:
                            with open(fpath, "rb") as f:
                                raw = f.read()
                            for line in raw.split(b"\n"):
                                line = line.strip()
                                if line:
                                    try:
                                        ev_list = parse_entry(
                                            json.loads(line), fpath)
                                        for ev in ev_list:
                                            ev["new"] = False
                                            broadcast(ev)
                                    except Exception:
                                        pass

                    elif stat.st_size > prev:
                        with open(fpath, "rb") as f:
                            f.seek(prev)
                            new_bytes = f.read()
                        _file_positions[key] = stat.st_size
                        for line in new_bytes.split(b"\n"):
                            line = line.strip()
                            if line:
                                try:
                                    ev_list = parse_entry(
                                        json.loads(line), fpath)
                                    for ev in ev_list:
                                        ev["new"] = True
                                        broadcast(ev)
                                except Exception:
                                    pass
                except Exception:
                    pass
        except Exception:
            pass
        time.sleep(POLL_INTERVAL)


